{
  "compileOnSave": true,
  "compilerOptions": {
    "rootDir": "src/",
    "outDir": "wwwroot/dist",
    "sourceMap": true,
    "target": "es6",
    "module": "amd",
    "declaration": false,
    "noImplicitAny": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "noEmitOnError": true
  },
  "filesGlob": [
    "./src/**/*.ts",
    "./test/**/*.ts",
    "./typings/index.d.ts",
    "./custom_typings/**/*.d.ts",
    "./wwwroot/jspm_packages/**/*.d.ts"
  ],
  "exclude": [
    "wwwroot/jspm_packages"
  ]
}
