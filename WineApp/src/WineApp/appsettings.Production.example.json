{
  // Copy this file to appsettings.Production.json and fill in real values.
  // appsettings.Production.json is git-ignored — never commit credentials.
  //
  // Alternatively, supply values via environment variables using the double-underscore
  // separator convention, e.g.:
  //   ConnectionStrings__MongoDB=mongodb://wineapp_user:s3cr3t@db.example.com:27017/wineapp
  //   MongoDbSettings__DatabaseName=wineapp
  //
  // MongoDB connection string recommendations for production:
  //   - Use a dedicated database user with read/write on the wineapp database only
  //   - Enable TLS:  mongodb://user:pass@host:27017/wineapp?tls=true
  //   - Prefer a connection string stored in a secrets manager (Azure Key Vault,
  //     AWS Secrets Manager, HashiCorp Vault) injected at deploy time.

  "ConnectionStrings": {
    "MongoDB": "mongodb://<USER>:<PASSWORD>@<HOST>:27017/<DBNAME>?tls=true"
  },
  "MongoDbSettings": {
    "DatabaseName": "<DBNAME>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
