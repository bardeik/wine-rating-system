@using System.Net.Http.Json
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar @(NavMenu?.IsSidebarCollapsed == true ? "collapsed" : "")">
        <NavMenu @ref="NavMenu" OnSidebarToggle="HandleSidebarToggle" />
    </div>

    <main class="@(NavMenu?.IsSidebarCollapsed == true ? "sidebar-collapsed" : "")">
        <div class="top-row px-4 d-flex align-items-center justify-content-end">
            <LoginDisplay />
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private NavMenu? NavMenu { get; set; }

    private void HandleSidebarToggle()
    {
        StateHasChanged();
    }
}
