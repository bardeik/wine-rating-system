@using System.Net.Http.Json
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar @(NavMenu?.IsMenuOpen == true ? "open" : "")">
        <NavMenu @ref="NavMenu" OnMenuToggle="HandleMenuToggle" />
    </div>

    @if (NavMenu?.IsMenuOpen == true)
    {
        <div class="nav-overlay-backdrop" @onclick="CloseMenu"></div>
    }

    <main>
        <div class="top-row px-4">
            <button class="hamburger-btn" @onclick="ToggleMenu" title="Meny">
                <span class="oi oi-menu" aria-hidden="true"></span>
            </button>
            <LoginDisplay />
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private NavMenu? NavMenu { get; set; }

    private void HandleMenuToggle() => StateHasChanged();

    private async Task ToggleMenu()
    {
        if (NavMenu != null) await NavMenu.ToggleMenu();
    }

    private async Task CloseMenu()
    {
        if (NavMenu != null) await NavMenu.CloseMenu();
    }
}
