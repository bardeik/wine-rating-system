@* 
    Shared decimal input that accepts both ',' and '.' as decimal separator.
    Uses <input type="text" inputmode="decimal"> so the browser never rejects a comma.
    Displays the current value with ',' as the decimal separator (Norwegian convention).
*@
<input type="text"
       inputmode="decimal"
       class="@Class"
       value="@_display"
       @oninput="HandleInput"
       @onblur="HandleBlur"
       placeholder="@Placeholder"
       disabled="@Disabled"
       id="@Id"
       @attributes="AdditionalAttributes" />

@code {
    [Parameter] public decimal Value { get; set; }
    [Parameter] public EventCallback<decimal> ValueChanged { get; set; }
    [Parameter] public string Class { get; set; } = "form-control";
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Id { get; set; }

    /// <summary>Absorbs unrecognised attributes (e.g. style, aria-*) without errors.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string _display = string.Empty;
    private bool _userTyping;

    protected override void OnParametersSet()
    {
        if (!_userTyping)
            _display = FormatDisplay(Value);
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        _userTyping = true;
        _display = e.Value?.ToString() ?? string.Empty;

        // Accept both ',' and '.' so Norwegian users can type either
        var normalized = _display.Replace(',', '.');
        if (decimal.TryParse(normalized,
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture,
                out var parsed))
        {
            await ValueChanged.InvokeAsync(parsed);
        }
    }

    private void HandleBlur()
    {
        _userTyping = false;
        _display = FormatDisplay(Value);
    }

    /// <summary>Shows the value with ',' as the decimal separator (nb-NO style).</summary>
    private static string FormatDisplay(decimal v) =>
        v.ToString("G", System.Globalization.CultureInfo.InvariantCulture).Replace('.', ',');
}
