@page "/judges"
@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Dommere</PageTitle>

<LoadingContainer IsLoading="@isLoading" Error="@loadError">

<h3>Dommere</h3>

<div class="card mb-3">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Navn</th>
                    <th>E-post</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in judgeUsers)
                {
                    <tr>
                        <td>@user.DisplayName</td>
                        <td>@user.Email</td>
                        <td>
                            <button @onclick="() => RemoveJudgeRole(user.Id.ToString())" class="btn btn-sm btn-danger">
                                <span>🗑️</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h4>Legg til ny dommer</h4>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <EditForm Model="@formModel" OnValidSubmit="@AddJudge">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Navn</label>
                <InputText @bind-Value="formModel.Name" class="form-control" placeholder="Navn" />
                <ValidationMessage For="@(() => formModel.Name)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">E-post</label>
                <InputText @bind-Value="formModel.Email" class="form-control" placeholder="E-post" />
                <ValidationMessage For="@(() => formModel.Email)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Passord</label>
                <InputText type="password" @bind-Value="formModel.Password" class="form-control" placeholder="Passord (minst 8 tegn)" />
                <ValidationMessage For="@(() => formModel.Password)" class="text-danger" />
            </div>
            <button type="submit" class="btn btn-primary">Legg til</button>
        </EditForm>
    </div>
</div>
</LoadingContainer>

@code {
    private bool isLoading = true;
    private string? loadError;
    private List<ApplicationUser> judgeUsers = new();
    private JudgeFormModel formModel = new();
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
        judgeUsers = (await UserManager.GetUsersInRoleAsync("Judge"))
            .OrderBy(u => u.DisplayName)
            .ToList();
        }
        catch (Exception ex)
        {
            loadError = $"Feil ved lasting av data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AddJudge()
    {
        errorMessage = string.Empty;
        var user = new ApplicationUser
        {
            UserName = formModel.Email,
            Email = formModel.Email,
            DisplayName = formModel.Name,
            EmailConfirmed = true
        };

        var result = await UserManager.CreateAsync(user, formModel.Password);
        if (!result.Succeeded)
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        await UserManager.AddToRoleAsync(user, "Judge");
        formModel = new JudgeFormModel();
        judgeUsers = (await UserManager.GetUsersInRoleAsync("Judge"))
            .OrderBy(u => u.DisplayName)
            .ToList();
    }

    private async Task RemoveJudgeRole(string userId)
    {
        var user = await UserManager.FindByIdAsync(userId);
        if (user is not null)
            await UserManager.RemoveFromRoleAsync(user, "Judge");

        judgeUsers = (await UserManager.GetUsersInRoleAsync("Judge"))
            .OrderBy(u => u.DisplayName)
            .ToList();
    }

}
