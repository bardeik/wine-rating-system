@page "/wineratings"
@attribute [Authorize]
@inject IWineRatingRepository WineRatingRepository

<PageTitle>Vurderinger</PageTitle>

<h3>Vurderinger</h3>

<div class="card">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Vurdering Id</th>
                    <th>Utseende</th>
                    <th>Nese</th>
                    <th>Smak</th>
                    <th>Dommer</th>
                    <th>Vin Id</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rating in wineRatings)
                {
                    <tr>
                        <td>@rating.WineRatingId</td>
                        <td>@rating.Visuality</td>
                        <td>@rating.Nose</td>
                        <td>@rating.Taste</td>
                        <td>@rating.JudgeId</td>
                        <td>@rating.WineId</td>
                        <td>
                            <button @onclick="() => DeleteWineRating(rating.WineRatingId)" class="btn btn-sm btn-danger">
                                <span>🗑️</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <hr />

        <h4>Legg til ny vurdering</h4>
        <EditForm Model="@newRating" OnValidSubmit="@AddNewWineRating">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Utseende (0-10)</label>
                <InputNumber @bind-Value="newRating.Visuality" class="form-control" placeholder="Utseende" />
                <ValidationMessage For="@(() => newRating.Visuality)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Nese (0-10)</label>
                <InputNumber @bind-Value="newRating.Nose" class="form-control" placeholder="Nese" />
                <ValidationMessage For="@(() => newRating.Nose)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Smak (0-10)</label>
                <InputNumber @bind-Value="newRating.Taste" class="form-control" placeholder="Smak" />
                <ValidationMessage For="@(() => newRating.Taste)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Dommer</label>
                <InputText @bind-Value="newRating.JudgeId" class="form-control" placeholder="Dommer" />
                <ValidationMessage For="@(() => newRating.JudgeId)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Vin Id</label>
                <InputNumber @bind-Value="newRating.WineId" class="form-control" placeholder="Vin Id" />
                <ValidationMessage For="@(() => newRating.WineId)" class="text-danger" />
            </div>
            <button type="submit" class="btn btn-primary">Legg til</button>
        </EditForm>
    </div>
</div>

@code {
    private List<WineRating> wineRatings = new();
    private WineRating newRating = new();

    protected override void OnInitialized()
    {
        LoadWineRatings();
    }

    private void LoadWineRatings()
    {
        wineRatings = WineRatingRepository.GetAllWineRatings().ToList();
    }

    private void AddNewWineRating()
    {
        WineRatingRepository.AddWineRating(newRating);
        newRating = new WineRating();
        LoadWineRatings();
    }

    private void DeleteWineRating(int wineRatingId)
    {
        WineRatingRepository.DeleteWineRating(wineRatingId);
        LoadWineRatings();
    }
}
