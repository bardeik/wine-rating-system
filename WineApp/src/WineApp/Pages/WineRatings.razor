@page "/wineratings"
@attribute [Authorize(Roles = "Admin,Judge")]
@inject IWineJudgingService WineJudging
@inject IWineCatalogService WineCatalog
@inject UserManager<ApplicationUser> UserManager
@inject CurrentUserState CurrentUser

<PageTitle>Vurderinger</PageTitle>

<LoadingContainer IsLoading="@isLoading" Error="@loadError">

@* ── Ratings table (Admin sees all + extra columns, Judge sees own only) ── *@
<h3>@(isAdmin ? "Vurderinger" : isJudge ? "Mine vurderinger" : "Vurderinger")</h3>
<div class="card mb-3">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    @if (isAdmin) { <th>Vurdering Id</th> }
                    <th>Utseende (A)</th>
                    <th>Nese (B)</th>
                    <th>Smak (C)</th>
                    <th>Total</th>
                    @if (isAdmin) { <th>Dommer</th> }
                    <th>Vin</th>
                    @if (canEdit) { <th></th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var rating in VisibleRatings)
                {
                    <tr>
                        @if (isAdmin) { <td>@rating.WineRatingId</td> }
                        <td>@rating.Appearance.ToString("F1")</td>
                        <td>@rating.Nose.ToString("F1")</td>
                        <td>@rating.Taste.ToString("F1")</td>
                        <td><strong>@rating.Total.ToString("F1")</strong></td>
                        @if (isAdmin) { <td>@rating.JudgeId</td> }
                        <td>@WineName(rating.WineId)</td>
                        @if (canEdit)
                        {
                            <td>
                                <button @onclick="() => DeleteWineRating(rating.WineRatingId)" class="btn btn-sm btn-danger">
                                    <span>🗑️</span>
                                </button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<hr />

@* ── Add rating form ── *@
@if (canEdit)
{
<div class="card">
    <div class="card-body">
        <h4>Legg til ny vurdering</h4>
        <EditForm Model="@newRating" OnValidSubmit="@AddNewWineRating">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Utseende (A) 0.0-3.0: <strong>@newRating.Appearance.ToString("F1")</strong></label>
                <DecimalInput @bind-Value="newRating.Appearance" Class="form-control" />
                <ValidationMessage For="@(() => newRating.Appearance)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Nese (B) 0.0-4.0: <strong>@newRating.Nose.ToString("F1")</strong></label>
                <DecimalInput @bind-Value="newRating.Nose" Class="form-control" />
                <ValidationMessage For="@(() => newRating.Nose)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Smak (C) 0.0-13.0: <strong>@newRating.Taste.ToString("F1")</strong></label>
                <DecimalInput @bind-Value="newRating.Taste" Class="form-control" />
                <ValidationMessage For="@(() => newRating.Taste)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Kommentar (valgfritt)</label>
                <InputTextArea @bind-Value="newRating.Comment" class="form-control" rows="3" />
                <ValidationMessage For="@(() => newRating.Comment)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Dommer</label>
                @if (currentUser is not null && isJudge)
                {
                    <input class="form-control" value="@(currentUser.DisplayName ?? currentUser.UserName)" disabled />
                }
                else
                {
                    <InputSelect @bind-Value="newRating.JudgeId" class="form-select">
                        <option value="">-- Velg dommer --</option>
                        @foreach (var u in judgeUsers)
                        {
                            <option value="@(u.DisplayName ?? u.UserName)">@(u.DisplayName ?? u.UserName)</option>
                        }
                    </InputSelect>
                }
                <ValidationMessage For="@(() => newRating.JudgeId)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Vin</label>
                <InputSelect @bind-Value="newRating.WineId" class="form-select">
                    <option value="">-- Velg vin --</option>
                    @foreach (var wine in wines)
                    {
                        <option value="@wine.WineId">@wine.RatingName – @wine.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => newRating.WineId)" class="text-danger" />
            </div>
            <button type="submit" class="btn btn-primary">Legg til</button>
        </EditForm>
    </div>
</div>
}
</LoadingContainer>

@code {
    private bool isLoading = true;
    private string? loadError;
    // ── State ──────────────────────────────────────────────
    private List<WineRating> wineRatings = new();
    private WineRating newRating = new();
    private List<Wine> wines = new();
    private List<ApplicationUser> judgeUsers = new();

    // ── Auth flags (resolved once in OnInitializedAsync) ──
    private bool isAdmin;
    private bool isJudge;
    private ApplicationUser? currentUser;

    private bool canEdit => isAdmin || isJudge;

    // ── Lifecycle ──────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
        await LoadWineRatings();
        wines = (await WineCatalog.GetAllWinesAsync()).ToList();
        judgeUsers = (await UserManager.GetUsersInRoleAsync("Judge"))
            .OrderBy(u => u.DisplayName)
            .ToList();

        await CurrentUser.EnsureInitializedAsync();
        isAdmin = CurrentUser.IsAdmin;
        isJudge = CurrentUser.IsJudge;

        if (!string.IsNullOrEmpty(CurrentUser.UserId))
            currentUser = await UserManager.FindByIdAsync(CurrentUser.UserId);

        if (currentUser is not null)
            newRating.JudgeId = currentUser.DisplayName ?? currentUser.UserName ?? string.Empty;
        }
        catch (Exception ex)
        {
            loadError = $"Feil ved lasting av data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Helpers ────────────────────────────────────────────
    private IEnumerable<WineRating> VisibleRatings =>
        isAdmin ? wineRatings :
        isJudge ? wineRatings.Where(r => r.JudgeId == (currentUser?.DisplayName ?? currentUser?.UserName)) :
        wineRatings;

    private string WineName(string wineId)
    {
        var wine = wines.FirstOrDefault(w => w.WineId == wineId);
        return wine is not null ? $"{wine.RatingName} – {wine.Name}" : wineId;
    }

    // ── Commands ───────────────────────────────────────────
    private async Task LoadWineRatings()
    {
        wineRatings = (await WineJudging.GetAllWineRatingsAsync()).ToList();
    }

    private async Task AddNewWineRating()
    {
        await WineJudging.AddWineRatingAsync(newRating);
        newRating = new WineRating();
        if (currentUser is not null)
            newRating.JudgeId = currentUser.DisplayName ?? currentUser.UserName ?? string.Empty;
        await LoadWineRatings();
    }

    private async Task DeleteWineRating(string wineRatingId)
    {
        await WineJudging.DeleteWineRatingAsync(wineRatingId);
        await LoadWineRatings();
    }
}
