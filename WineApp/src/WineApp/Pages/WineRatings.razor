@page "/wineratings"
@attribute [Authorize]
@inject IWineRatingRepository WineRatingRepository
@inject IWineRepository WineRepository
@inject IJudgeRepository JudgeRepository

<PageTitle>Vurderinger</PageTitle>

<h3>Vurderinger</h3>

<div class="card">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Vurdering Id</th>
                    <th>Utseende</th>
                    <th>Nese</th>
                    <th>Smak</th>
                    <th>Dommer</th>
                    <th>Vin</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rating in wineRatings)
                {
                    <tr>
                        <td>@rating.WineRatingId</td>
                        <td>@rating.Visuality</td>
                        <td>@rating.Nose</td>
                        <td>@rating.Taste</td>
                        <td>@rating.JudgeId</td>
                        <td>@(wines.FirstOrDefault(w => w.WineId == rating.WineId)?.RatingName ?? rating.WineId) – @(wines.FirstOrDefault(w => w.WineId == rating.WineId)?.Name ?? string.Empty)</td>
                        <td>
                            <button @onclick="() => DeleteWineRating(rating.WineRatingId)" class="btn btn-sm btn-danger">
                                <span>🗑️</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <hr />

        <h4>Legg til ny vurdering</h4>
        <EditForm Model="@newRating" OnValidSubmit="@AddNewWineRating">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Utseende (0-10): <strong>@newRating.Visuality</strong></label>
                <input type="range" min="0" max="10" step="1"
                       class="form-range"
                       @bind="newRating.Visuality"
                       @bind:event="oninput" />
                <ValidationMessage For="@(() => newRating.Visuality)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Nese (0-10): <strong>@newRating.Nose</strong></label>
                <input type="range" min="0" max="10" step="1"
                       class="form-range"
                       @bind="newRating.Nose"
                       @bind:event="oninput" />
                <ValidationMessage For="@(() => newRating.Nose)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Smak (0-10): <strong>@newRating.Taste</strong></label>
                <input type="range" min="0" max="10" step="1"
                       class="form-range"
                       @bind="newRating.Taste"
                       @bind:event="oninput" />
                <ValidationMessage For="@(() => newRating.Taste)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Dommer</label>
                <InputSelect @bind-Value="newRating.JudgeId" class="form-select">
                    <option value="">-- Velg dommer --</option>
                    @foreach (var judge in judges)
                    {
                        <option value="@judge.Name">@judge.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => newRating.JudgeId)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Vin</label>
                <InputSelect @bind-Value="newRating.WineId" class="form-select">
                    <option value="">-- Velg vin --</option>
                    @foreach (var wine in wines)
                    {
                        <option value="@wine.WineId">@wine.RatingName – @wine.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => newRating.WineId)" class="text-danger" />
            </div>
            <button type="submit" class="btn btn-primary">Legg til</button>
        </EditForm>
    </div>
</div>

@code {
    private List<WineRating> wineRatings = new();
    private WineRating newRating = new();
    private List<Wine> wines = new();
    private List<Judge> judges = new();

    protected override void OnInitialized()
    {
        LoadWineRatings();
        wines = WineRepository.GetAllWines().ToList();
        judges = JudgeRepository.GetAllJudges().ToList();
    }

    private void LoadWineRatings()
    {
        wineRatings = WineRatingRepository.GetAllWineRatings().ToList();
    }

    private void AddNewWineRating()
    {
        WineRatingRepository.AddWineRating(newRating);
        newRating = new WineRating();
        LoadWineRatings();
    }

    private void DeleteWineRating(string wineRatingId)
    {
        WineRatingRepository.DeleteWineRating(wineRatingId);
        LoadWineRatings();
    }
}
