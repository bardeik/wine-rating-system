@page "/wineproducers"
@attribute [Authorize(Roles = "Admin,WineProducer")]
@inject IWineProducerRepository WineProducerRepository

<PageTitle>Vinprodusenter</PageTitle>

<h3>Vinprodusenter</h3>

<div class="card">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Vinprodusent Id</th>
                    <th>Vingårdsnavn</th>
                    <th>Organisasjonsnummer</th>
                    <th>Ansvarlig produsent</th>
                    <th>Adresse</th>
                    <th>Postnummer</th>
                    <th>By</th>
                    <th>Land</th>
                    <th>E-post</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var producer in wineProducers)
                {
                    <tr>
                        <td>@producer.WineProducerId</td>
                        <td>@producer.WineyardName</td>
                        <td>@producer.OrganisationNumber</td>
                        <td>@producer.ResponsibleProducerName</td>
                        <td>@producer.Address</td>
                        <td>@producer.Zip</td>
                        <td>@producer.City</td>
                        <td>@producer.Country</td>
                        <td>@producer.Email</td>
                        <td>
                            <button @onclick="() => DeleteWineProducer(producer.WineProducerId)" class="btn btn-sm btn-danger">
                                <span>🗑️</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <hr />

        <h4>Legg til ny vinprodusent</h4>
        <EditForm Model="@newProducer" OnValidSubmit="@AddNewWineProducer">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Vingårdsnavn</label>
                <InputText @bind-Value="newProducer.WineyardName" class="form-control" placeholder="Vingårdsnavn" />
                <ValidationMessage For="@(() => newProducer.WineyardName)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Organisasjonsnummer</label>
                <InputText @bind-Value="newProducer.OrganisationNumber" class="form-control" placeholder="Organisasjonsnummer" />
                <ValidationMessage For="@(() => newProducer.OrganisationNumber)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Ansvarlig produsent</label>
                <InputText @bind-Value="newProducer.ResponsibleProducerName" class="form-control" placeholder="Ansvarlig produsent" />
                <ValidationMessage For="@(() => newProducer.ResponsibleProducerName)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Adresse</label>
                <InputText @bind-Value="newProducer.Address" class="form-control" placeholder="Adresse" />
                <ValidationMessage For="@(() => newProducer.Address)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Postnummer</label>
                <InputText @bind-Value="newProducer.Zip" class="form-control" placeholder="Postnummer" />
                <ValidationMessage For="@(() => newProducer.Zip)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">By</label>
                <InputText @bind-Value="newProducer.City" class="form-control" placeholder="By" />
                <ValidationMessage For="@(() => newProducer.City)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Land</label>
                <InputText @bind-Value="newProducer.Country" class="form-control" placeholder="Land" />
                <ValidationMessage For="@(() => newProducer.Country)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">E-post</label>
                <InputText @bind-Value="newProducer.Email" class="form-control" placeholder="E-post" />
                <ValidationMessage For="@(() => newProducer.Email)" class="text-danger" />
            </div>
            <button type="submit" class="btn btn-primary">Legg til</button>
        </EditForm>
    </div>
</div>

@code {
    private List<WineProducer> wineProducers = new();
    private WineProducer newProducer = new();

    protected override void OnInitialized()
    {
        LoadWineProducers();
    }

    private void LoadWineProducers()
    {
        wineProducers = WineProducerRepository.GetAllWineProducers().ToList();
    }

    private void AddNewWineProducer()
    {
        WineProducerRepository.AddWineProducer(newProducer);
        newProducer = new WineProducer();
        LoadWineProducers();
    }

    private void DeleteWineProducer(string wineProducerId)
    {
        WineProducerRepository.DeleteWineProducer(wineProducerId);
        LoadWineProducers();
    }
}
