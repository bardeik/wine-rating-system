@page "/account/change-password"
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserMgr
@inject SignInManager<ApplicationUser> SignInMgr
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Endre passord</PageTitle>

<div class="container mt-4" style="max-width:480px;">
    <h3>Endre passord</h3>
    <hr />

    <StatusAlert Message="@statusMessage" CssClass="@statusClass" OnDismiss="() => statusMessage = string.Empty" />

    <EditForm Model="@form" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Nåværende passord</label>
            <InputText type="password" class="form-control" @bind-Value="form.CurrentPassword" autocomplete="current-password" />
            <ValidationMessage For="() => form.CurrentPassword" class="text-danger small" />
        </div>
        <div class="mb-3">
            <label class="form-label">Nytt passord</label>
            <InputText type="password" class="form-control" @bind-Value="form.NewPassword" autocomplete="new-password" />
            <ValidationMessage For="() => form.NewPassword" class="text-danger small" />
        </div>
        <div class="mb-3">
            <label class="form-label">Bekreft nytt passord</label>
            <InputText type="password" class="form-control" @bind-Value="form.ConfirmPassword" autocomplete="new-password" />
            <ValidationMessage For="() => form.ConfirmPassword" class="text-danger small" />
        </div>

        <button type="submit" class="btn btn-dark w-100" disabled="@isSaving">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Endre passord
        </button>
    </EditForm>
</div>

@code {
    private ChangePasswordFormModel form = new();
    private string statusMessage = string.Empty;
    private string statusClass = "alert-info";
    private bool isSaving;

    private async Task HandleSubmit()
    {
        isSaving = true;
        statusMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = await UserMgr.GetUserAsync(authState.User);
            if (user is null)
            {
                Nav.NavigateTo("/Account/Login", forceLoad: true);
                return;
            }

            var result = await UserMgr.ChangePasswordAsync(user, form.CurrentPassword, form.NewPassword);
            if (result.Succeeded)
            {
                // Refresh the security stamp so the existing cookie stays valid
                await SignInMgr.RefreshSignInAsync(user);
                form = new();
                statusMessage = "Passord endret.";
                statusClass = "alert-success";
            }
            else
            {
                statusMessage = string.Join(" ", result.Errors.Select(e => e.Description));
                statusClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
            statusClass = "alert-danger";
        }
        finally
        {
            isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private sealed class ChangePasswordFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Obligatorisk")]
        [System.ComponentModel.DataAnnotations.DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        public string CurrentPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Obligatorisk")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Minst 8 tegn")]
        [System.ComponentModel.DataAnnotations.DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        public string NewPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Obligatorisk")]
        [System.ComponentModel.DataAnnotations.Compare(nameof(NewPassword), ErrorMessage = "Passordene er ikke like")]
        [System.ComponentModel.DataAnnotations.DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
