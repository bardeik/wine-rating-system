@page "/wines"
@attribute [Authorize]
@inject IWineRepository WineRepository
@inject IWineProducerRepository WineProducerRepository

<PageTitle>Viner</PageTitle>

<h3>Viner</h3>

<div class="card">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Vin Id</th>
                    <th>Vurderingsnavn</th>
                    <th>Navn</th>
                    <th>Gruppe</th>
                    <th>Klasse</th>
                    <th>Kategori</th>
                    <th>Vinprodusent</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var wine in wines)
                {
                    <tr>
                        <td>@wine.WineId</td>
                        <td>@wine.RatingName</td>
                        <td>@wine.Name</td>
                        <td>@wine.Group</td>
                        <td>@wine.Class</td>
                        <td>@wine.Category</td>
                        <td>@(wineProducers.FirstOrDefault(p => p.WineProducerId == wine.WineProducerId)?.WineyardName ?? wine.WineProducerId)</td>
                        <td>
                            <button @onclick="() => DeleteWine(wine.WineId)" class="btn btn-sm btn-danger">
                                <span>🗑️</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <hr />

        <h4>Legg til ny vin</h4>
        <EditForm Model="@newWine" OnValidSubmit="@AddNewWine">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Vurderingsnavn</label>
                <InputText @bind-Value="newWine.RatingName" class="form-control" placeholder="Vurderingsnavn" />
                <ValidationMessage For="@(() => newWine.RatingName)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Navn</label>
                <InputText @bind-Value="newWine.Name" class="form-control" placeholder="Navn" />
                <ValidationMessage For="@(() => newWine.Name)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Gruppe</label>
                <InputSelect @bind-Value="newWine.Group" class="form-control">
                    <option value="">Velg gruppe</option>
                    @foreach (var group in Enum.GetValues<WineGroup>())
                    {
                        <option value="@group">@group</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => newWine.Group)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Klasse</label>
                <InputSelect @bind-Value="newWine.Class" class="form-control">
                    <option value="">Velg klasse</option>
                    @foreach (var wineClass in Enum.GetValues<WineClass>())
                    {
                        <option value="@wineClass">@wineClass</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => newWine.Class)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Kategori</label>
                <InputSelect @bind-Value="newWine.Category" class="form-control">
                    <option value="">Velg kategori</option>
                    @foreach (var category in Enum.GetValues<WineCategory>())
                    {
                        <option value="@category">@category</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => newWine.Category)" class="text-danger" />
            </div>
            <div class="mb-3">
                <label class="form-label">Vinprodusent</label>
                <InputSelect @bind-Value="newWine.WineProducerId" class="form-select">
                    <option value="">-- Velg vinprodusent --</option>
                    @foreach (var producer in wineProducers)
                    {
                        <option value="@producer.WineProducerId">@producer.WineyardName</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => newWine.WineProducerId)" class="text-danger" />
            </div>
            <button type="submit" class="btn btn-primary">Legg til</button>
        </EditForm>
    </div>
</div>

@code {
    private List<Wine> wines = new();
    private Wine newWine = new();
    private List<WineProducer> wineProducers = new();

    protected override void OnInitialized()
    {
        LoadWines();
        wineProducers = WineProducerRepository.GetAllWineProducers().ToList();
    }

    private void LoadWines()
    {
        wines = WineRepository.GetAllWines().ToList();
    }

    private void AddNewWine()
    {
        WineRepository.AddWine(newWine);
        newWine = new Wine();
        LoadWines();
    }

    private void DeleteWine(string wineId)
    {
        WineRepository.DeleteWine(wineId);
        LoadWines();
    }
}
