@page "/wines"
@attribute [Authorize(Roles = "Admin,WineProducer")]
@inject IWineRepository WineRepository
@inject IWineProducerRepository WineProducerRepository
@inject AuthenticationStateProvider AuthenticationStateProvider
@using System.Security.Claims

<PageTitle>Viner</PageTitle>

@* ── Wines table ── *@
<h3>@(isAdmin ? "Viner" : isWineProducer ? "Mine viner" : "Viner")</h3>
<div class="card mb-3">
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    @if (isAdmin) { <th>Vin Id</th> }
                    <th>Vurderingsnavn</th>
                    <th>Navn</th>
                    <th>Gruppe</th>
                    <th>Klasse</th>
                    <th>Kategori</th>
                    @if (isAdmin) { <th>Vinprodusent</th> }
                    @if (canEdit) { <th></th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var wine in VisibleWines)
                {
                    <tr>
                        @if (isAdmin) { <td>@wine.WineId</td> }
                        <td>@wine.RatingName</td>
                        <td>@wine.Name</td>
                        <td>@wine.Group</td>
                        <td>@wine.Class</td>
                        <td>@wine.Category</td>
                        @if (isAdmin)
                        {
                            <td>@(wineProducers.FirstOrDefault(p => p.WineProducerId == wine.WineProducerId)?.WineyardName ?? wine.WineProducerId)</td>
                        }
                        @if (canEdit)
                        {
                            <td class="text-nowrap">
                                <button @onclick="() => StartEdit(wine)" class="btn btn-sm btn-secondary me-1">✏️</button>
                                <button @onclick="() => DeleteWine(wine.WineId)" class="btn btn-sm btn-danger">🗑️</button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<hr />

@* ── Edit form (shown when a wine is selected for editing) ── *@
@if (canEdit && editingWine is not null)
{
    <div class="card border-warning mb-3">
        <div class="card-header bg-warning text-dark">Rediger vin</div>
        <div class="card-body">
            <EditForm Model="@editingWine" OnValidSubmit="@SaveEdit">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                @WineFormFields(editingWine)
                <button type="submit" class="btn btn-warning me-2">Lagre</button>
                <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Avbryt</button>
            </EditForm>
        </div>
    </div>
}

@* ── Add form ── *@
@if (canEdit)
{
<div class="card">
    <div class="card-body">
        <h4>Legg til ny vin</h4>
        <EditForm Model="@newWine" OnValidSubmit="@AddNewWine">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />
            @WineFormFields(newWine)
            <button type="submit" class="btn btn-primary">Legg til</button>
        </EditForm>
    </div>
</div>
}

@code {
    private List<Wine> wines = new();
    private Wine newWine = new();
    private Wine? editingWine;
    private List<WineProducer> wineProducers = new();

    // ── Auth ───────────────────────────────────────────────
    private bool isAdmin;
    private bool isWineProducer;
    private WineProducer? currentProducer;

    private bool canEdit => isAdmin || isWineProducer;

    private IEnumerable<Wine> VisibleWines =>
        isAdmin ? wines :
        isWineProducer ? wines.Where(w => w.WineProducerId == currentProducer?.WineProducerId) :
        wines;

    protected override async Task OnInitializedAsync()
    {
        LoadWines();
        wineProducers = WineProducerRepository.GetAllWineProducers().ToList();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isAdmin = user.IsInRole("Admin");
        isWineProducer = user.IsInRole("WineProducer");

        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (isWineProducer && userId is not null)
        {
            currentProducer = WineProducerRepository.GetWineProducerByUserId(userId);
            if (currentProducer is not null)
                newWine.WineProducerId = currentProducer.WineProducerId;
        }
    }

    private void LoadWines() =>
        wines = WineRepository.GetAllWines().ToList();

    private void AddNewWine()
    {
        WineRepository.AddWine(newWine);
        newWine = new Wine();
        if (currentProducer is not null)
            newWine.WineProducerId = currentProducer.WineProducerId;
        LoadWines();
    }

    private void StartEdit(Wine wine) =>
        editingWine = new Wine
        {
            WineId = wine.WineId,
            RatingName = wine.RatingName,
            Name = wine.Name,
            Group = wine.Group,
            Class = wine.Class,
            Category = wine.Category,
            WineProducerId = wine.WineProducerId
        };

    private void SaveEdit()
    {
        if (editingWine is not null)
            WineRepository.UpdateWine(editingWine);
        editingWine = null;
        LoadWines();
    }

    private void CancelEdit() => editingWine = null;

    private void DeleteWine(string wineId)
    {
        WineRepository.DeleteWine(wineId);
        LoadWines();
    }

    // ── Shared form fields rendered as a RenderFragment ───
    private RenderFragment WineFormFields(Wine wine) => __builder =>
    {
        <div class="mb-3">
            <label class="form-label">Vurderingsnavn</label>
            <InputText @bind-Value="wine.RatingName" class="form-control" />
            <ValidationMessage For="@(() => wine.RatingName)" class="text-danger" />
        </div>
        <div class="mb-3">
            <label class="form-label">Navn</label>
            <InputText @bind-Value="wine.Name" class="form-control" />
            <ValidationMessage For="@(() => wine.Name)" class="text-danger" />
        </div>
        <div class="mb-3">
            <label class="form-label">Gruppe</label>
            <InputSelect @bind-Value="wine.Group" class="form-select">
                <option value="">Velg gruppe</option>
                @foreach (var g in Enum.GetValues<WineGroup>()) { <option value="@g">@g</option> }
            </InputSelect>
        </div>
        <div class="mb-3">
            <label class="form-label">Klasse</label>
            <InputSelect @bind-Value="wine.Class" class="form-select">
                <option value="">Velg klasse</option>
                @foreach (var c in Enum.GetValues<WineClass>()) { <option value="@c">@c</option> }
            </InputSelect>
        </div>
        <div class="mb-3">
            <label class="form-label">Kategori</label>
            <InputSelect @bind-Value="wine.Category" class="form-select">
                <option value="">Velg kategori</option>
                @foreach (var cat in Enum.GetValues<WineCategory>()) { <option value="@cat">@cat</option> }
            </InputSelect>
        </div>
        @if (isAdmin)
        {
            <div class="mb-3">
                <label class="form-label">Vinprodusent</label>
                <InputSelect @bind-Value="wine.WineProducerId" class="form-select">
                    <option value="">-- Velg vinprodusent --</option>
                    @foreach (var p in wineProducers)
                    {
                        <option value="@p.WineProducerId">@p.WineyardName</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => wine.WineProducerId)" class="text-danger" />
            </div>
        }
    };
}
