@page "/reports"
@attribute [Authorize]
@inject IReportService ReportService

<PageTitle>Rapporter</PageTitle>

<LoadingContainer IsLoading="@isLoading" Error="@loadError">

<h3>Vurderingsrapport</h3>

@if (!reportRows.Any())
{
    <div class="alert alert-info">Ingen viner er vurdert enda.</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Vurderingsnavn</th>
                        <th>Navn</th>
                        <th>Gruppe</th>
                        <th>Klasse</th>
                        <th>Kategori</th>
                        <th>Vinprodusent</th>
                        <th class="text-center">Utseende (A)</th>
                        <th class="text-center">Nese (B)</th>
                        <th class="text-center">Smak (C)</th>
                        <th class="text-center">Total</th>
                        <th class="text-center">Vurderinger</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var row in reportRows)
                    {
                        <tr class="@(rank == 1 ? "table-warning" : rank == 2 ? "table-secondary" : rank == 3 ? "table-light" : "")">
                            <td><strong>@rank</strong></td>
                            <td>@row.RatingName</td>
                            <td>@row.Name</td>
                            <td>@row.Group</td>
                            <td>@row.Class</td>
                            <td>@row.Category</td>
                            <td>@row.ProducerName</td>
                            <td class="text-center">
                                @ScoreBadge(row.AvgAppearance)
                            </td>
                            <td class="text-center">
                                @ScoreBadge(row.AvgNose)
                            </td>
                            <td class="text-center">
                                @ScoreBadge(row.AvgTaste)
                            </td>
                            <td class="text-center">
                                <strong>@row.Total.ToString("F1")</strong>
                                <div class="progress mt-1" style="height:6px">
                                    <div class="progress-bar bg-success"
                                         style="width:@((row.Total / 20.0 * 100).ToString("F0"))%">
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@row.RatingCount</span>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}
</LoadingContainer>

@code {
    private List<WineReportRow> reportRows = new();
    private bool isLoading = true;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            reportRows = await ReportService.GetWineReportRowsAsync();
        }
        catch (Exception ex)
        {
            loadError = $"Feil ved lasting av rapport: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private RenderFragment ScoreBadge(double score) => __builder =>
    {
        var css = score >= 14 ? "bg-success" : score >= 10 ? "bg-warning text-dark" : "bg-danger";
        <span class="badge @css">@score.ToString("F1")</span>
    };
}
