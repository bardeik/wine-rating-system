@page "/reports"
@attribute [Authorize]
@inject IWineRepository WineRepository
@inject IWineRatingRepository WineRatingRepository
@inject IWineProducerRepository WineProducerRepository

<PageTitle>Rapporter</PageTitle>

@if (isLoading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Laster...</span>
        </div>
    </div>
}
else if (loadError != null)
{
    <div class="alert alert-danger"><strong>Feil:</strong> @loadError</div>
}
else
{

<h3>Vurderingsrapport</h3>

@if (!reportRows.Any())
{
    <div class="alert alert-info">Ingen viner er vurdert enda.</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Vurderingsnavn</th>
                        <th>Navn</th>
                        <th>Gruppe</th>
                        <th>Klasse</th>
                        <th>Kategori</th>
                        <th>Vinprodusent</th>
                        <th class="text-center">Utseende (A)</th>
                        <th class="text-center">Nese (B)</th>
                        <th class="text-center">Smak (C)</th>
                        <th class="text-center">Total</th>
                        <th class="text-center">Vurderinger</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var row in reportRows)
                    {
                        <tr class="@(rank == 1 ? "table-warning" : rank == 2 ? "table-secondary" : rank == 3 ? "table-light" : "")">
                            <td><strong>@rank</strong></td>
                            <td>@row.RatingName</td>
                            <td>@row.Name</td>
                            <td>@row.Group</td>
                            <td>@row.Class</td>
                            <td>@row.Category</td>
                            <td>@row.ProducerName</td>
                            <td class="text-center">
                                @ScoreBadge(row.AvgAppearance)
                            </td>
                            <td class="text-center">
                                @ScoreBadge(row.AvgNose)
                            </td>
                            <td class="text-center">
                                @ScoreBadge(row.AvgTaste)
                            </td>
                            <td class="text-center">
                                <strong>@row.Total.ToString("F1")</strong>
                                <div class="progress mt-1" style="height:6px">
                                    <div class="progress-bar bg-success"
                                         style="width:@((row.Total / 20.0 * 100).ToString("F0"))%">
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@row.RatingCount</span>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}
}

@code {
    private List<WineReportRow> reportRows = new();
    private bool isLoading = true;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var wines     = await WineRepository.GetAllWinesAsync();
        var ratings   = await WineRatingRepository.GetAllWineRatingsAsync();
        var producers = await WineProducerRepository.GetAllWineProducersAsync();

        reportRows = wines
            .Select(wine =>
            {
                var wineRatings  = ratings.Where(r => r.WineId == wine.WineId).ToList();
                var producerName = producers.FirstOrDefault(p => p.WineProducerId == wine.WineProducerId)?.WineyardName ?? "–";

                decimal avgApp  = wineRatings.Any() ? wineRatings.Average(r => r.Appearance) : 0;
                decimal avgNose = wineRatings.Any() ? wineRatings.Average(r => r.Nose)       : 0;
                decimal avgTaste= wineRatings.Any() ? wineRatings.Average(r => r.Taste)      : 0;

                return new WineReportRow
                {
                    RatingName   = wine.RatingName,
                    Name         = wine.Name,
                    Group        = wine.Group.ToString(),
                    Class        = wine.Class.ToString(),
                    Category     = wine.Category.ToString(),
                    ProducerName = producerName,
                    AvgAppearance = (double)avgApp,
                    AvgNose      = (double)avgNose,
                    AvgTaste     = (double)avgTaste,
                    Total        = (double)(avgApp + avgNose + avgTaste),
                    RatingCount  = wineRatings.Count
                };
            })
            .OrderByDescending(r => r.Total)
            .ToList();
        }
        catch (Exception ex)
        {
            loadError = $"Feil ved lasting av rapport: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private RenderFragment ScoreBadge(double score) => __builder =>
    {
        var css = score >= 14 ? "bg-success" : score >= 10 ? "bg-warning text-dark" : "bg-danger";
        <span class="badge @css">@score.ToString("F1")</span>
    };

    private class WineReportRow
    {
        public string RatingName   { get; set; } = string.Empty;
        public string Name         { get; set; } = string.Empty;
        public string Group        { get; set; } = string.Empty;
        public string Class        { get; set; } = string.Empty;
        public string Category     { get; set; } = string.Empty;
        public string ProducerName { get; set; } = string.Empty;
        public double AvgAppearance { get; set; }
        public double AvgNose      { get; set; }
        public double AvgTaste     { get; set; }
        public double Total        { get; set; }
        public int    RatingCount  { get; set; }
    }
}
