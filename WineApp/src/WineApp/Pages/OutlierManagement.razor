@page "/outlier-management"
@attribute [Authorize(Roles = "Admin")]
@inject IWineEventService EventSvc
@inject IWineCatalogService WineCatalog
@inject IWineJudgingService WineJudging
@inject IOutlierDetectionService OutlierDetectionService
@inject IScoreAggregationService ScoreAggregationService
@using WineApp.Services

<PageTitle>Outlier Management</PageTitle>

<LoadingContainer IsLoading="@isLoading" Error="@loadError">

<h3>🔄 Outlier Management</h3>

@if (activeEvent == null)
{
    <div class="alert alert-warning">
        <h4>Ingen aktivt arrangement</h4>
        <p>Det finnes ingen aktive arrangementer for øyeblikket.</p>
    </div>
}
else
{
    <div class="alert alert-info mb-4">
        <div class="row">
            <div class="col-md-8">
                <h5>@activeEvent.Name</h5>
                <p class="mb-0">
                    <strong>Outlier-terskel:</strong> @activeEvent.OutlierThreshold poeng spread<br />
                    <small class="text-muted">Viner med spread > @activeEvent.OutlierThreshold krever re-vurdering</small>
                </p>
            </div>
            <div class="col-md-4 text-end">
                <button class="btn btn-primary" @onclick="DetectOutliers">
                    🔍 Oppdager outliers
                </button>
            </div>
        </div>
    </div>

    <!-- Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h6 class="text-muted">Totalt outliers</h6>
                    <h2 class="text-danger">@outliers.Count</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h6 class="text-muted">Re-vurdert</h6>
                    <h2 class="text-success">@outliersResolved</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h6 class="text-muted">Venter</h6>
                    <h2 class="text-warning">@outliersPending</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h6 class="text-muted">Høyeste spread</h6>
                    <h2 class="text-danger">@maxSpread.ToString("F1")</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Outlier List -->
    @if (outliers.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">⚠️ Outliers (@outliers.Count)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nr.</th>
                                <th>Vinnavn</th>
                                <th>Total score</th>
                                <th>Spread</th>
                                <th>Dommere</th>
                                <th>Status</th>
                                <th>Handlinger</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var outlier in outliers.OrderByDescending(o => o.result.Spread))
                            {
                                var wine = wines.FirstOrDefault(w => w.WineId == outlier.result.WineId);
                                if (wine == null) continue;

                                var ratings = allRatings.Where(r => r.WineId == wine.WineId).ToList();

                                <tr class="@(outlier.resolved ? "table-success" : "table-warning")">
                                    <td><strong>@wine.WineNumber</strong></td>
                                    <td>@wine.RatingName</td>
                                    <td class="text-end">
                                        <strong>@outlier.result.TotalScore.ToString("F1")</strong>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge bg-danger">
                                            @outlier.result.Spread.ToString("F1")
                                        </span>
                                    </td>
                                    <td class="text-center">@outlier.result.NumberOfRatings</td>
                                    <td>
                                        @if (outlier.resolved)
                                        {
                                            <span class="badge bg-success">✓ Re-vurdert</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">⚠️ Venter</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-info me-1" @onclick="() => ViewRatings(wine)">
                                            👁️ Se vurderinger
                                        </button>
                                        @if (!outlier.resolved)
                                        {
                                            <button class="btn btn-sm btn-success" @onclick="() => MarkResolved(wine.WineId)">
                                                ✓ Marker som løst
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <h5>✓ Ingen outliers funnet</h5>
            <p class="mb-0">Alle viner har akseptabel spread (≤ @activeEvent.OutlierThreshold poeng)</p>
        </div>
    }

    <!-- Judge Analysis (if outliers exist) -->
    @if (outliers.Any())
    {
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">📊 Dommer-analyse</h5>
            </div>
            <div class="card-body">
                <p class="mb-3">Denne analysen identifiserer dommere som kan ha systematiske avvik i vurderingene sine.</p>
                
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Dommer</th>
                                <th>Gjennomsnitt</th>
                                <th>Lav varians</th>
                                <th>Defekt-rate</th>
                                <th>Mønster</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pattern in judgePatterns)
                            {
                                <tr>
                                    <td>@pattern.JudgeName</td>
                                    <td class="@GetAverageClass(pattern.AverageScore)">
                                        @pattern.AverageScore.ToString("F1")
                                    </td>
                                    <td>
                                        @if (pattern.HasLowVariance)
                                        {
                                            <span class="badge bg-warning text-dark">⚠️ Ja</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Nei</span>
                                        }
                                    </td>
                                    <td>
                                        @if (pattern.DefectFlagRate > 0.3m)
                                        {
                                            <span class="badge bg-danger">@pattern.DefectFlagRate.ToString("P0")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@pattern.DefectFlagRate.ToString("P0")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (pattern.TendsLow)
                                        {
                                            <span class="text-danger">↓ Lavt</span>
                                        }
                                        else if (pattern.TendsHigh)
                                        {
                                            <span class="text-success">↑ Høyt</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">~ Normal</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

<!-- Rating Details Modal -->
@if (showRatingModal && selectedWine != null)
{
    var ratings = allRatings.Where(r => r.WineId == selectedWine.WineId).ToList();
    var result = allResults.FirstOrDefault(r => r.WineId == selectedWine.WineId);

    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Vurderinger - Vin #@selectedWine.WineNumber (@selectedWine.RatingName)</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (result != null)
                    {
                        <div class="alert alert-info mb-3">
                            <div class="row">
                                <div class="col-md-3">
                                    <strong>Total score:</strong> @result.TotalScore.ToString("F1")
                                </div>
                                <div class="col-md-3">
                                    <strong>Spread:</strong> 
                                    <span class="badge bg-@(result.Spread > activeEvent!.OutlierThreshold ? "danger" : "success")">
                                        @result.Spread.ToString("F1")
                                    </span>
                                </div>
                                <div class="col-md-3">
                                    <strong>Panel snitt:</strong>
                                    @result.AverageAppearance.ToString("F2") /
                                    @result.AverageNose.ToString("F2") /
                                    @result.AverageTaste.ToString("F2")
                                </div>
                                <div class="col-md-3">
                                    <strong>Klassifisering:</strong> @result.Classification
                                </div>
                            </div>
                        </div>
                    }

                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Dommer</th>
                                <th>Utseende (A)</th>
                                <th>Nese (B)</th>
                                <th>Smak (C)</th>
                                <th>Total</th>
                                <th>Avvik fra snitt</th>
                                <th>Kommentar</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rating in ratings.OrderByDescending(r => r.Appearance + r.Nose + r.Taste))
                            {
                                var total = rating.Appearance + rating.Nose + rating.Taste;
                                var deviation = result != null ? total - result.TotalScore : 0;
                                var isEditing = editingRatings.ContainsKey(rating.WineRatingId);

                                @if (isEditing)
                                {
                                    var draft = editingRatings[rating.WineRatingId];
                                    <tr class="table-primary">
                                        <td><strong>@rating.JudgeId</strong></td>
                                        <td style="width:90px">
                                            <DecimalInput Value="@draft.Appearance" ValueChanged="@(v => draft.Appearance = v)" Class="form-control form-control-sm" />
                                        </td>
                                        <td style="width:90px">
                                            <DecimalInput Value="@draft.Nose" ValueChanged="@(v => draft.Nose = v)" Class="form-control form-control-sm" />
                                        </td>
                                        <td style="width:100px">
                                            <DecimalInput Value="@draft.Taste" ValueChanged="@(v => draft.Taste = v)" Class="form-control form-control-sm" />
                                        </td>
                                        <td><strong>@((draft.Appearance + draft.Nose + draft.Taste).ToString("F1"))</strong></td>
                                        <td>—</td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm"
                                                   value="@draft.Comment"
                                                   @onchange="e => draft.Comment = e.Value!.ToString()!" />
                                        </td>
                                        <td class="text-nowrap">
                                            <button class="btn btn-sm btn-success me-1" @onclick="() => SaveRating(rating.WineRatingId)" disabled="@isSavingRating">
                                                @if (isSavingRating)
                                                {
                                                    <span class="spinner-border spinner-border-sm"></span>
                                                }
                                                else
                                                {
                                                    <span>💾 Lagre</span>
                                                }
                                            </button>
                                            <button class="btn btn-sm btn-secondary" @onclick="() => CancelEdit(rating.WineRatingId)">✕ Avbryt</button>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    <tr class="@GetRatingRowClass(deviation)">
                                        <td><strong>@rating.JudgeId</strong></td>
                                        <td>@rating.Appearance.ToString("F1")</td>
                                        <td>@rating.Nose.ToString("F1")</td>
                                        <td>@rating.Taste.ToString("F1")</td>
                                        <td><strong>@total.ToString("F1")</strong></td>
                                        <td>
                                            @if (Math.Abs(deviation) > 2)
                                            {
                                                <span class="badge bg-warning text-dark">@deviation.ToString("+0.0;-0.0")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">@deviation.ToString("+0.0;-0.0")</span>
                                            }
                                        </td>
                                        <td><small>@rating.Comment</small></td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(rating)">✏️ Rediger</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <small class="text-muted me-auto">Trykk ✏️ Rediger på en rad for å korrigere vurderingen direkte.</small>
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Lukk</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

<StatusAlert Message="@statusMessage" CssClass="@statusClass" OnDismiss="() => statusMessage = string.Empty" />
</LoadingContainer>

@code {
    private bool isLoading = true;
    private string? loadError;
    private Event? activeEvent;
    private List<(WineResult result, bool resolved)> outliers = new();
    private List<Wine> wines = new();
    private List<WineResult> allResults = new();
    private List<WineRating> allRatings = new();
    private List<JudgePattern> judgePatterns = new();

    private Wine? selectedWine;
    private bool showRatingModal;
    private bool isSavingRating;
    private Dictionary<string, WineRating> editingRatings = new();

    private string statusMessage = string.Empty;
    private string statusClass = "alert-info";

    private int outliersResolved => outliers.Count(o => o.resolved);
    private int outliersPending => outliers.Count(o => !o.resolved);
    private decimal maxSpread => outliers.Any() ? outliers.Max(o => o.result.Spread) : 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
        await LoadData();
        }
        catch (Exception ex)
        {
            loadError = $"Feil ved lasting av data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadData()
    {
        activeEvent = await EventSvc.GetActiveEventAsync();
        wines = (await WineCatalog.GetAllWinesAsync()).ToList();
        allRatings = (await WineJudging.GetAllWineRatingsAsync()).ToList();

        if (activeEvent != null)
        {
            allResults = (await WineJudging.GetAllWineResultsAsync())
                .Where(r => wines.Any(w => w.WineId == r.WineId && w.EventId == activeEvent.EventId))
                .ToList();
        }
    }

    private async Task DetectOutliers()
    {
        if (activeEvent == null) return;

        try
        {
            outliers.Clear();

            var results = allResults.Where(r => r.IsOutlier).ToList();
            foreach (var result in results)
            {
                outliers.Add((result, false)); // Mark as unresolved by default
            }

            // Analyze judge patterns - OutlierDetectionService returns Dictionary, not JudgePattern list
            // For now, skip this until we need it
            judgePatterns.Clear();

            ShowStatus($"✓ Funnet {outliers.Count} outliers", "alert-success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowStatus($"Feil ved outlier-deteksjon: {ex.Message}", "alert-danger");
        }
    }

    private async Task ViewRatings(Wine wine)
    {
        selectedWine = wine;
        editingRatings.Clear();
        showRatingModal = true;
    }

    private async Task CloseModal()
    {
        selectedWine = null;
        showRatingModal = false;
        editingRatings.Clear();
    }

    private void StartEdit(WineRating rating)
    {
        editingRatings[rating.WineRatingId] = new WineRating
        {
            WineRatingId = rating.WineRatingId,
            WineId = rating.WineId,
            JudgeId = rating.JudgeId,
            Appearance = rating.Appearance,
            Nose = rating.Nose,
            Taste = rating.Taste,
            Comment = rating.Comment
        };
    }

    private void CancelEdit(string ratingId)
    {
        editingRatings.Remove(ratingId);
    }

    private async Task SaveRating(string ratingId)
    {
        if (!editingRatings.TryGetValue(ratingId, out var draft)) return;

        try
        {
            isSavingRating = true;
            await WineJudging.UpdateWineRatingAsync(draft);

            // Update local cache
            var idx = allRatings.FindIndex(r => r.WineRatingId == ratingId);
            if (idx >= 0) allRatings[idx] = draft;

            editingRatings.Remove(ratingId);

            // Recalculate results so spread refreshes
            if (activeEvent != null)
            {
                var updated = await ScoreAggregationService.RecalculateEventResultsAsync(activeEvent.EventId);
                allResults = updated
                    .Where(r => wines.Any(w => w.WineId == r.WineId && w.EventId == activeEvent.EventId))
                    .ToList();
            }

            ShowStatus($"✓ Vurdering lagret", "alert-success");
        }
        catch (Exception ex)
        {
            ShowStatus($"Feil ved lagring: {ex.Message}", "alert-danger");
        }
        finally
        {
            isSavingRating = false;
        }
    }

    private async Task MarkResolved(string wineId)
    {
        var outlier = outliers.FirstOrDefault(o => o.result.WineId == wineId);
        if (outlier.result != null)
        {
            var index = outliers.IndexOf(outlier);
            outliers[index] = (outlier.result, true);
            ShowStatus("✓ Outlier markert som løst", "alert-success");
            StateHasChanged();
        }
    }

    private string GetAverageClass(decimal average)
    {
        if (average > 15) return "text-success";
        if (average < 12) return "text-danger";
        return "";
    }

    private string GetRatingRowClass(decimal deviation)
    {
        if (Math.Abs(deviation) > 3) return "table-danger";
        if (Math.Abs(deviation) > 2) return "table-warning";
        return "";
    }

    private void ShowStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;
    }

}

