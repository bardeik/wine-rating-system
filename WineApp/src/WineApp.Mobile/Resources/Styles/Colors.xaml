<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Wine-red brand palette -->
    <Color x:Key="Primary">#8B0000</Color>
    <Color x:Key="PrimaryDark">#5C0000</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#DFD3C3</Color>
    <Color x:Key="SecondaryDarkText">#3D2B1F</Color>
    <Color x:Key="Tertiary">#2B0A0A</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="OffWhite">#F7F5F2</Color>

    <!-- Functional -->
    <Color x:Key="PageBackgroundColor">#FFFFFF</Color>
    <Color x:Key="CardBackgroundColor">#F7F5F2</Color>

</ResourceDictionary>
