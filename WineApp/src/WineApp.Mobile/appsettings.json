{
  // Server URL that the mobile app connects to.
  //
  // Local development:
  //   iOS Simulator : "https://localhost:5001" or "http://localhost:5000"
  //   Android Emulator: "http://10.0.2.2:5000"  (emulator loopback to host machine)
  //
  // Production: copy this file to appsettings.Production.json (gitignored),
  //   set BaseUrl to the deployed server URL, then rebuild and publish.
  //   Alternatively, your CI/CD pipeline can substitute this value before the build.
  //   Example: "https://wine-rating-system.fly.dev"
  "AppConfig": {
    "BaseUrl": "https://localhost:5001"
  }
}
