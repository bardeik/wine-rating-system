@inherits LayoutComponentBase

<div class="mobile-layout">
    <!-- Top navigation bar -->
    <header class="mobile-topbar">
        <div class="mobile-topbar-inner">
            <span class="mobile-app-title">🍷 VinApp</span>
        </div>
    </header>

    <!-- Main content area -->
    <main class="mobile-content">
        @Body
    </main>

    <!-- Bottom tab navigation -->
    <nav class="mobile-bottomnav" role="navigation" aria-label="Hovednavigasjon">
        <a href="/judge/rating" class="mobile-tab" @onclick:preventDefault="false">
            <span class="mobile-tab-icon">⭐</span>
            <span class="mobile-tab-label">Vurdering</span>
        </a>
        <a href="/wines" class="mobile-tab" @onclick:preventDefault="false">
            <span class="mobile-tab-icon">🍇</span>
            <span class="mobile-tab-label">Viner</span>
        </a>
        <a href="/results" class="mobile-tab" @onclick:preventDefault="false">
            <span class="mobile-tab-icon">🏅</span>
            <span class="mobile-tab-label">Resultater</span>
        </a>
        <a href="/Account/Logout" class="mobile-tab" @onclick:preventDefault="false">
            <span class="mobile-tab-icon">🚪</span>
            <span class="mobile-tab-label">Logg ut</span>
        </a>
    </nav>
</div>
