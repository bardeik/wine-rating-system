@page "/wines"
@using WineApp.Shared.Dtos
@using WineApp.Shared.MobileServices
@inject IMobileWineService WineService

<PageTitle>Viner</PageTitle>

<div class="container-fluid px-3 pb-5">
    <div class="py-3">
        <h5 class="fw-bold mb-0">🍇 Viner i arrangementet</h5>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height: 50vh;">
            <div class="text-center">
                <div class="spinner-border text-danger" role="status"></div>
                <p class="mt-2 text-muted">Laster viner...</p>
            </div>
        </div>
    }
    else if (loadError is not null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Feil:</strong> @loadError
        </div>
    }
    else
    {
        <!-- Search -->
        <div class="mb-3">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0">🔍</span>
                <input type="search"
                       class="form-control border-start-0"
                       placeholder="Søk på navn, kategori, land..."
                       @bind="searchTerm"
                       @bind:event="oninput" />
            </div>
        </div>

        <!-- Count -->
        <p class="text-muted small mb-2">
            Viser @filteredWines.Count() av @allWines.Count viner
        </p>

        <!-- Wine list -->
        @if (!filteredWines.Any())
        {
            <div class="alert alert-info">Ingen viner matcher søket.</div>
        }
        else
        {
            <div class="list-group">
                @foreach (var wine in filteredWines)
                {
                    <div class="list-group-item list-group-item-action border rounded mb-2 px-3 py-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    @if (wine.WineNumber.HasValue)
                                    {
                                        <span class="badge bg-secondary">#@wine.WineNumber</span>
                                    }
                                    <span class="fw-semibold">@wine.RatingName</span>
                                </div>
                                <p class="mb-1 text-muted small">
                                    @wine.Name — Årgang @wine.Vintage
                                </p>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    <span class="badge rounded-pill bg-light text-dark border">@wine.Category</span>
                                    <span class="badge rounded-pill bg-light text-dark border">@wine.Group</span>
                                    <span class="badge rounded-pill bg-light text-dark border">@wine.Country</span>
                                </div>
                            </div>
                            <div class="text-end text-muted small ms-2 text-nowrap">
                                @wine.AlcoholPercentage%
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private string? loadError;
    private string searchTerm = string.Empty;

    private IList<WineDto> allWines = [];

    private IEnumerable<WineDto> filteredWines =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? allWines
            : allWines.Where(w =>
                w.RatingName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                w.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                w.Category.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                w.Group.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                w.Country.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allWines = await WineService.GetWinesForActiveEventAsync();
        }
        catch (Exception ex)
        {
            loadError = $"Kunne ikke laste viner: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
