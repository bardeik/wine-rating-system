@page "/results"
@using WineApp.Shared.Dtos
@using WineApp.Shared.MobileServices
@inject IMobileEventService EventService

<PageTitle>Resultater</PageTitle>

<div class="container-fluid px-3 pb-5">
    <div class="py-3">
        <h5 class="fw-bold mb-0">🏅 Resultater</h5>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height: 50vh;">
            <div class="text-center">
                <div class="spinner-border text-danger" role="status"></div>
                <p class="mt-2 text-muted">Laster...</p>
            </div>
        </div>
    }
    else if (loadError is not null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Feil:</strong> @loadError
        </div>
    }
    else if (activeEvent is null)
    {
        <div class="alert alert-info">
            Ingen aktiv konkurranse for øyeblikket.
        </div>
    }
    else
    {
        <!-- Event header -->
        <div class="card border-0 bg-danger text-white mb-4">
            <div class="card-body text-center py-4">
                <h4 class="card-title fw-bold mb-1">@activeEvent.Name</h4>
                <p class="card-text opacity-75 mb-0">@activeEvent.Year</p>
            </div>
        </div>

        <!-- Thresholds -->
        <h6 class="fw-semibold mb-3">Medaljeterskel</h6>
        <div class="row g-2 mb-4">
            <div class="col-6">
                <div class="card text-center border-0 bg-warning bg-opacity-25">
                    <div class="card-body py-3">
                        <div class="fs-4">🥇</div>
                        <div class="fw-bold">Gull</div>
                        <div class="text-muted small">≥ @activeEvent.GoldThreshold poeng</div>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card text-center border-0 bg-secondary bg-opacity-10">
                    <div class="card-body py-3">
                        <div class="fs-4">🥈</div>
                        <div class="fw-bold">Sølv</div>
                        <div class="text-muted small">≥ @activeEvent.SilverThreshold poeng</div>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card text-center border-0 bg-warning bg-opacity-10">
                    <div class="card-body py-3">
                        <div class="fs-4">🥉</div>
                        <div class="fw-bold">Bronse</div>
                        <div class="text-muted small">≥ @activeEvent.BronzeThreshold poeng</div>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card text-center border-0 bg-info bg-opacity-10">
                    <div class="card-body py-3">
                        <div class="fs-4">⭐</div>
                        <div class="fw-bold">Særlig utmerkelse</div>
                        <div class="text-muted small">≥ @activeEvent.SpecialMeritThreshold poeng</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gate values -->
        <h6 class="fw-semibold mb-2">Gate-verdier (minimumspoeng)</h6>
        <table class="table table-sm table-bordered mb-4">
            <tbody>
                <tr>
                    <td>Utseende (A)</td>
                    <td class="text-end fw-semibold">@activeEvent.AppearanceGateValue</td>
                </tr>
                <tr>
                    <td>Nese (B)</td>
                    <td class="text-end fw-semibold">@activeEvent.NoseGateValue</td>
                </tr>
                <tr>
                    <td>Smak (C)</td>
                    <td class="text-end fw-semibold">@activeEvent.TasteGateValue</td>
                </tr>
            </tbody>
        </table>

        <!-- Note -->
        <div class="alert alert-info d-flex align-items-start gap-2" role="alert">
            <span class="fs-5">ℹ️</span>
            <div>
                <strong>Detaljerte resultater</strong> — Fullstendige rangeringer, trofévinnere
                og eksportrapporter er tilgjengelig på webapplikasjonen etter at arrangementet
                er avsluttet og resultatene er publisert.
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string? loadError;
    private EventDto? activeEvent;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            activeEvent = await EventService.GetActiveEventAsync();
        }
        catch (Exception ex)
        {
            loadError = $"Kunne ikke laste arrangement: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
