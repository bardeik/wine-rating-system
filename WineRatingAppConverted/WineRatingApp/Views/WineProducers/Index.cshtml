@model IEnumerable<WineRatingApp.Models.WineProducer>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.WineyardName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ResponsibleProducerName)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Address)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.City)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Country)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Zip)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Email)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.OrganisationNumber)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.WineyardName)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.ResponsibleProducerName)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Address)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.City)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Country)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Zip)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Email)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.OrganisationNumber)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.WineProducerId }) |
            @Html.ActionLink("Details", "Details", new { id=item.WineProducerId }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.WineProducerId })
        </td>
    </tr>
}

</table>
