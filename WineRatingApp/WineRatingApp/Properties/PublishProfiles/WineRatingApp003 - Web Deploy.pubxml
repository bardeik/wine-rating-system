<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <ADUsesOwinOrOpenIdConnect>False</ADUsesOwinOrOpenIdConnect>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>http://wineratingapp003.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>True</LaunchSiteAfterPublish>
    <ExcludeApp_Data>False</ExcludeApp_Data>
    <MSDeployServiceURL>wineratingapp003.scm.azurewebsites.net:443</MSDeployServiceURL>
    <DeployIisAppPath>WineRatingApp003</DeployIisAppPath>
    <RemoteSitePhysicalPath />
    <SkipExtraFilesOnServer>True</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>True</EnableMSDeployBackup>
    <UserName>$WineRatingApp003</UserName>
    <_SavePWD>True</_SavePWD>
    <_DestinationType>AzureWebSite</_DestinationType>
    <PublishDatabaseSettings>
      <Objects xmlns="">
        <ObjectGroup Name="DefaultConnection" Order="1" Enabled="True">
          <Destination Path="Data Source=tcp:wineratingdb.database.windows.net,1433;Initial Catalog=WineRatingApp20170111095410_db;User ID=dbadmin@wineratingdb;Password=SommerTid01." Name="Data Source=tcp:wineratingdb.database.windows.net,1433;Initial Catalog=WineRatingApp20170111095410_db;User Id=dbadmin@wineratingdb;Password=SommerTid01." />
          <Object Type="DbCodeFirst">
            <Source Path="DBMigration" DbContext="WineRatingApp.Models.ApplicationDbContext, WineRatingApp" MigrationConfiguration="WineRatingApp.Migrations.Configuration, WineRatingApp" Origin="Configuration" />
          </Object>
        </ObjectGroup>
      </Objects>
    </PublishDatabaseSettings>
  </PropertyGroup>
  <ItemGroup>
    <MSDeployParameterValue Include="$(DeployParameterPrefix)DefaultConnection-Web.config Connection String">
      <ParameterValue>Data Source=tcp:wineratingdb.database.windows.net,1433;Initial Catalog=WineRatingApp20170111095410_db;User Id=dbadmin@wineratingdb;Password=SommerTid01.</ParameterValue>
    </MSDeployParameterValue>
  </ItemGroup>
</Project>