@model WineRatingApp.Models.WineRating

@{
    ViewBag.Title = "Edit";
}

<h2>Edit</h2>


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    
    <div class="form-horizontal">
        <h4>WineRating</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.WineRatingId)

        <div class="form-group">
            @Html.LabelFor(model => model.JudgeId, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.JudgeId, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.JudgeId, "", new { @class = "text-danger" })
            </div>
        </div>
@if (User.IsInRole("Administrator"))
{
        <div class="form-group">
            @Html.LabelFor(model => model.WineId, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.WineId, WineRatingApp.Models.GlobalLists.WineIdJudgeSelectList(Model.WineId) as List<SelectListItem>)
            </div>
        </div>
}
else
{
    @Html.HiddenFor(model => model.WineId)
}

        <div class="form-group">
            @Html.LabelFor(model => model.Visuality, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.Visuality, WineRatingApp.Models.GlobalLists.WineRatingVisualitySelectList(Model.Visuality) as List<SelectListItem>)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Nose, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.Nose, WineRatingApp.Models.GlobalLists.WineRatingNoseSelectList(Model.Nose) as List<SelectListItem>)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Taste, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.Taste, WineRatingApp.Models.GlobalLists.WineRatingTasteSelectList(Model.Taste) as List<SelectListItem>)
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Save" class="btn btn-default" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Back to List", "Index")
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
